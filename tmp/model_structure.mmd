%% CoPRA 模型结构（Mermaid 格式）
%% 文件: tmp/model_structure.mmd
%% 参考图示：顶端为输入与两个 LM，中心为 CoFormer 融合模块（含 structure-guided attention），下方为 Structure-Sequence Fusion 子模块示意，右侧为预训练/下游任务。

flowchart TD
  %% ---------- Inputs & LMs ----------
  subgraph Inputs
    ProtInput["Protein complex / full protein seq\n(prot)"]
    NaInput["RNA full seq\n(na)"]
    StructFile["Structure file (.cif/.pdb)\n(atomic coords)"]
  end

  ProtInput --> ESM["ESM (protein LM)"]
  NaInput  --> RINALMO["RiNALMo (RNA LM)"]

  ESM --> ProtEmb["prot_embedding (LM features)"]
  RINALMO --> NaEmb["na_embedding (LM features)"]

  subgraph Projection
    ProjectionLabel["Projection & Interface Feature"]
    ProtProj["project_feat / proj_cplx\n(可选投影)"]
    NaProj["proj_cplx"]
    Interface1D["Interface 1D Embedding\n(pooled / token)"]
    InterfacePair["Interface Pair Embedding\n(pair / atom-level)"]
  end

  ProtEmb --> ProtProj
  NaEmb  --> NaProj
  ProtProj --> Interface1D
  NaProj   --> Interface1D

  StructFile --> PairEnc["pair_encoder -> z\n(atom / pair 表征)"]
  PairEnc --> InterfacePair

  %% ---------- Structure-Sequence Fusion Module (简化示意) ----------
  subgraph Fusion
    FusionLabel["Structure-Sequence Fusion Module"]
    direction LR
    S1["1D Embedding (seq)"] --> LQ["Linear -> Queries"]
    S1 --> LK["Linear -> Keys"]
    S1 --> LV["Linear -> Values"]
    P1["Pair Embedding (z)"] --> PL["Linear -> Pair features"]
    LK --> ATT["Attention (task mask)\nsoftmax -> weighted values"]
    LV --> ATT
    ATT --> OUT1["Outer Product / Combine -> 1D embed"]
    PL --> OUT2["Pair features -> integrate to pair embedding"]
    OUT1 --> Interface1D
    OUT2 --> InterfacePair
  end

  %% ---------- CoFormer (cross-modal transformer) ----------
  subgraph CoFormerBlock
    CoFormerLabel["CoFormer (cross-modal transformer)\n接收 Interface 1D 与 Pair z"]
    direction TB
    CoFormerMain["CoFormer main\n(Structure-guided MHA, Outer product, FFN x N)"]
    ProtTok["prot pooled token (super token)"]
    NaTok["rna pooled token (super token)"]
    ComplexEmb["complex_embedding / pooled token(s)"]
  end

  Interface1D --> CoFormerMain
  InterfacePair --> CoFormerMain
  CoFormerMain --> ProtTok
  CoFormerMain --> NaTok

  %% ---------- 双编码器互作器（InteractionAdapter） ----------
  subgraph Interaction
    InteractionLabel["双编码器互作器\nInteractionAdapter (双向)"]
    direction LR
    IA1["prot <- rna\n( cross-attn )"]
    IA2["rna <- prot\n( cross-attn )"]
  end
  ProtTok -->|query| IA1
  NaTok  -->|kv| IA1
  NaTok -->|query| IA2
  ProtTok -->|kv| IA2
  IA1 -->|updated prot| CoFormerMain
  IA2 -->|updated rna| CoFormerMain

  CoFormerMain --> ComplexEmb
  ComplexEmb --> PredHead["pred_head -> dG (finetune)"]
  PairEnc --> DistHead["dist_head -> dist_logits\n(pretune: 原子/残基距离预测)"]

  %% ---------- Pretraining & Downstream notes ----------
  subgraph Tasks
    TasksLabel["Tasks"]
    Pretune["Pretune: dist_logits + similarity (prot↔rna cosine)"]
    Finetune["Finetune: dG via pred_head"]
    Down["Downstream: affinity / affinity change"]
  end
  DistHead --> Pretune
  PredHead --> Finetune
  PredHead --> Down

  %% LoRA note
  classDef lm fill:#f3f4ff,stroke:#666,stroke-width:1px;
  class ESM,RINALMO lm
  Note3["LoRA: 可包裹 ESM/RiNALMo，仅训练 adapter/LoRA 参数"]
  ESM --> Note3
  RINALMO --> Note3

  %% InteractionAdapter 详细注释
  subgraph Notes
    InteractionDetail["双编码器互作层 (InteractionAdapter)\n- 作用：在 pooled/prot 与 pooled/rna 表示之间做轻量级的跨模态 cross-attention。\n- 结构：`MultiheadAttention` (batch_first=True) + 残差 + LayerNorm + 小型 FFN。\n- 用法：query=(B,Q,E), ext_kv=(B,K,E)，常见 Q=1, K=1 或少量锚点。\n- 配置：embed_dim/num_heads/dropout 从 `copra.yml` 读取。"]
  end

  %% layout hints
  class ProtInput,NaInput,StructFile internal

%% End of diagram
